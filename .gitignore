# Raw media stays out of the repo (large; processed renditions are pipeline output)
*.zip
BlindSail-JJ-1/
6-13 Sailing -pk/
*.mp4
*.MP4
*.HEIC
*.heic
*.mov
*.MOV

# Local-only real-media QA (never committed/deployed)
media/local/
media.local.json

# Publishing pipeline working state & secrets (never committed)
# (secrets/* not secrets/ — ignoring the directory itself would make git never
# descend into it, so the !.gitkeep negation would be dead.)
pipeline/runs/
secrets/*
!secrets/.gitkeep
config/*.local.json
scripts/pipeline/node_modules/

# Remotion reel renderer
remotion/node_modules/
remotion/public/run/

# Claude Code worktrees (local only) — keep skills/ committable
.claude/worktrees/
